[sub_resource type="GDScript" id="GDScript_0wfyh"]
resource_name = "Camera Movement"
script/source = "extends Camera2D

func _process(delta: float) -> void:
	var direction_x = Input.get_axis(\"left\", \"right\")
	var direction_y = Input.get_axis(\"up\", \"down\")
	var direction_z = Input.get_axis(\"zoom_in\", \"zoom_out\")
	var speed = get_meta(\"speed\") * delta * 100
	
	position += Vector2(direction_x, direction_y).normalized() * speed
	zoom += Vector2.ONE * direction_z
"

